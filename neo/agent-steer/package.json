{
  "name": "agent-steer",
  "description": "manifest.json description",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build && pnpm run postbuild",
    "build:firefox": "wxt build -b firefox && pnpm run postbuild",
    "postbuild": "node scripts/strip-rrweb-utf8-bad-chars.mjs",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rrweb": "2.0.0-alpha.20"
  },
  "devDependencies": {
    "@rrweb/types": "2.0.0-alpha.20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "typescript": "^5.9.3",
    "wxt": "^0.20.26"
  }
}
