{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "types": ["chrome", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["./components/*"],
      "@/common/*": ["./src/common/*"],
      "@/lib/*": ["./src/common/*"],
      "@/views/*": ["./src/views/*"]
    }
  }
}