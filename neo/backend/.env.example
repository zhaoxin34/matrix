# Application
APP_NAME="Neo Agent API"
DEBUG=true
API_V1_PREFIX="/api/v1"

# Database
DATABASE_URL="mysql+pymysql://root:root@localhost:3306/neo_agent"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Security
JWT_SECRET_KEY="your-secret-key-change-in-production"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=1440

# AI Providers
OPENAI_API_KEY=""
CLAUDE_API_KEY=""

# AI Rate Limiting
AI_RATE_LIMIT_REQUESTS=100
AI_RATE_LIMIT_WINDOW=60

# Server
HOST="0.0.0.0"
PORT=8000

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="plain"
LOG_OUTPUT="both"
LOG_DIR="logs"
LOG_FILE="app.log"
