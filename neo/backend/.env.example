# Application
APP_NAME="Neo Agent API"
DEBUG=true
API_V1_PREFIX="/api/v1"

# Database
DATABASE_URL="mysql+pymysql://root:root@localhost:3306/neo_agent"

# Redis
REDIS_URL="redis://localhost:6379/0"

# Security
JWT_SECRET_KEY="your-secret-key-change-in-production"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=1440

# AI Providers — knlg-base Phase 3 (LLM Gateway + AI 访谈 Agent)
# Phase 3 spec §15.1: Fernet master key for api_key encryption at rest.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
KNLG_LLM_KEY_ENCRYPTION_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# AI Rate Limiting — knlg-base Phase 3 §3.5 (cost_guard.py, Redis INCR + EXPIRE, ≤ 100/user/小时)
KNLG_AI_RATE_LIMIT_PER_HOUR=100

# Feature flag — knlg-base Phase 3 §15.6 紧急关闭开关；默认开启
KNLG_AI_INTERVIEW_ENABLED=true

# Redis（限流 + Prompt 缓存共用）— Phase 3 §15.3
# REDIS_URL 见上文“# Redis”节

# Server
HOST="0.0.0.0"
PORT=8000

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="plain"
LOG_OUTPUT="both"
LOG_DIR="logs"
LOG_FILE="app.log"

# RustFS (S3-compatible storage)
RUSTFS_ENDPOINT="http://localhost:9000"
RUSTFS_ACCESS_KEY="rustfsadmin"
RUSTFS_SECRET_KEY="rustfsadmin123"
RUSTFS_REGION="us-east-1"
RUSTFS_BUCKET="neo-agent"
RUSTFS_PRESIGNED_EXPIRES=3600
