{
  "name": "@neo/dom-snapshot",
  "version": "0.1.0",
  "description": "把任意 DOM 树压缩成 LLM 友好的扁平结构 (id/role/name),并提供 click/fill 双向操作。",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "./dist/dom-snapshot.cjs",
  "module": "./dist/dom-snapshot.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/dom-snapshot.js",
      "require": "./dist/dom-snapshot.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "rm -rf dist && vite build --config vite.config.lib.ts && tsc -p tsconfig.json --emitDeclarationOnly --outDir dist",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,html}\" \"tests/**/*.ts\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "happy-dom": "^15.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "dom",
    "snapshot",
    "a11y",
    "aria",
    "llm",
    "agent",
    "browser"
  ]
}
