{
  "name": "@neo/front-component",
  "version": "0.2.0",
  "description": "neo 的浏览器工程化组件库: dom-snapshot(0.2)、aria-tree(计划中)、playwright-rpc(计划中)。",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dom-snapshot": {
      "types": "./dist/dom-snapshot/index.d.ts",
      "import": "./dist/dom-snapshot/index.js",
      "require": "./dist/dom-snapshot/index.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "rm -rf dist && vite build --config vite.config.lib.ts && tsc -p tsconfig.json --emitDeclarationOnly --outDir dist",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"demo/**/*.{ts,css,html}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"demo/**/*.{ts,css,html}\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "happy-dom": "^15.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "dom",
    "snapshot",
    "a11y",
    "aria",
    "llm",
    "agent",
    "browser"
  ]
}
