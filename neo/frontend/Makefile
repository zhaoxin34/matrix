.PHONY: install dev build start lint format typecheck test clean

# 安装依赖
install:
	pnpm install

# 开发模式
dev:
	pnpm dev

# 构建生产版本
build:
	pnpm build

# 启动生产服务器
start:
	pnpm start

# 代码检查
lint:
	pnpm lint

# 代码格式化
format:
	pnpm format

# 类型检查
typecheck:
	pnpm typecheck

# 运行测试 (预留)
test:
	@echo "No test command configured"

# 清理构建产物
clean:
	rm -rf .next
