# =============================================================================
# Frontend env (copy to .env and fill in)
# =============================================================================
#
# VITE_API_URL — absolute origin of the pi-web-01 backend, including the
# port. The frontend appends "/api/..." to this for every request, and
# uses it as the origin for the SSE EventSource.
#
# Vite env convention: only `VITE_*` vars are exposed to client code, and
# they're read via `import.meta.env` (not `process.env`).
#
# Examples:
#   - localhost dev:        http://localhost:30141
#   - LAN access from phone: http://192.168.1.10:30141
#   - public domain:         https://pi.example.com
#
# If left unset, the frontend falls back to same-origin relative URLs
# (`/api/...`), which only works when the backend is reverse-proxied at
# the same hostname. For any cross-origin setup, set this.
#
VITE_API_URL=http://localhost:30141
