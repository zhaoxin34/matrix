#!/bin/bash
# Pre-commit hook - runs lint check for backend and frontend

echo "Running pre-commit lint check..."

# Backend checks
echo "Checking backend..."
cd ecommerce/backend || exit 1

echo "Running pre-commit checks..."

# Run ruff check with --fix for auto-fix
echo "Running ruff check with auto-fix..."
uv run ruff check --fix src/ tests/
if [ $? -ne 0 ]; then
  echo "Backend linting failed. Please fix the issues above."
  exit 1
fi

# Verify no lint errors remain
echo "Verifying backend lint..."
uv run ruff check src/ tests/
if [ $? -ne 0 ]; then
  echo "Backend linting failed. Please fix the issues above."
  exit 1
fi

# Run pytest
echo "Running pytest..."
uv run pytest

echo "All checks passed!"

cd ../..

# Frontend checks
echo "Checking frontend..."
cd ecommerce/frontend || exit 1

# Auto-fix lint issues first
echo "Running eslint with auto-fix..."
npm run lint -- --fix

# Then verify all issues fixed
echo "Verifying frontend lint..."
npm run lint
if [ $? -ne 0 ]; then
  echo "Frontend linting failed. Please fix the issues above."
  exit 1
fi

npm run type-check
if [ $? -ne 0 ]; then
  echo "Frontend type check failed. Please fix the issues above."
  exit 1
fi

cd ../..

echo "Pre-commit check passed!"
exit 0
