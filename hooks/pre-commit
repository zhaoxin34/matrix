#!/bin/bash
# Pre-commit hook - runs lint check for backend and frontend

echo "Running pre-commit lint check..."

# Define projects to check
PROJECTS="ecommerce cdp"

for project in $PROJECTS; do
  echo "========================================"
  echo "Checking $project..."

  # Backend checks
  echo "Checking $project backend..."
  cd $project/backend || exit 1

  echo "Running ruff check with auto-fix..."
  uv run ruff check --fix src/ tests/
  if [ $? -ne 0 ]; then
    echo "$project backend linting failed. Please fix the issues above."
    exit 1
  fi

  echo "Verifying $project backend lint..."
  uv run ruff check src/ tests/
  if [ $? -ne 0 ]; then
    echo "$project backend linting failed. Please fix the issues above."
    exit 1
  fi

  echo "Running pytest for $project backend..."
  uv run pytest

  echo "$project backend checks passed!"
  cd ../..

  # Frontend checks
  echo "Checking $project frontend..."
  cd $project/frontend || exit 1

  echo "Running eslint with auto-fix..."
  npm run lint -- --fix

  echo "Verifying $project frontend lint..."
  npm run lint
  if [ $? -ne 0 ]; then
    echo "$project frontend linting failed. Please fix the issues above."
    exit 1
  fi

  echo "Running type-check for $project frontend..."
  npm run type-check
  if [ $? -ne 0 ]; then
    echo "$project frontend type check failed. Please fix the issues above."
    exit 1
  fi

  echo "$project frontend checks passed!"
  cd ../..
done

echo "========================================"
echo "Pre-commit check passed!"
exit 0
