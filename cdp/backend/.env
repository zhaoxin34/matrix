# Application
APP_NAME="CDP API"
DEBUG=True
API_V1_PREFIX="/api/v1"

# Database
DB_USER="root"
DB_PASSWORD="root"
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_NAME="cdp"
DATABASE_URL="mysql+pymysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"

# Security
SECRET_KEY="your-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server
HOST="0.0.0.0"
PORT=8001

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=plain
LOG_OUTPUT=both
LOG_DIR=logs
LOG_FILE=cdp-backend.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
