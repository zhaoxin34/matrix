# Application
APP_NAME="CDP API"
DEBUG=True
API_V1_PREFIX="/api/v1"

# Database
DATABASE_URL="mysql+pymysql://root:root@127.0.0.1:3306/cdp"

# Security
SECRET_KEY="your-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server
HOST="0.0.0.0"
PORT=8001

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="json"
# both console file
LOG_OUTPUT="both"
LOG_DIR="logs"
LOG_FILE="app.log"
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
