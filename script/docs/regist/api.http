### 

# 电商网站 API HTTP 文件
# 使用 kulala.nvim 或 REST Client 插件

@baseUrl = http://localhost:8000/api/v1
@testEmail = 13800138002@example.com
@testPassword = abcd1234
@testPhone = 13800138002
@username = user2

# @shared


### 注册新用户

# @name registerUser

POST {{baseUrl}}/auth/register HTTP/1.1
Content-Type: application/json

{
  "email": "{{testEmail}}",
  "password": "{{testPassword}}",
  "phone": "{{testPhone}}",
  "username": "{{username}}"
}


### 登录

# @name loginUser

POST {{baseUrl}}/auth/login HTTP/1.1
Content-Type: application/json

{
  "password": "{{testPassword}}",
  "phone": "{{testPhone}}"
}


### 获取当前用户信息

# @name getMe

GET {{baseUrl}}/auth/me HTTP/1.1
Authorization: Bearer {{loginUser.response.body.access_token}}


### 刷新 Token

# @name refreshToken

POST {{baseUrl}}/auth/refresh HTTP/1.1
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}


### 登出

# @name logout

POST {{baseUrl}}/auth/logout HTTP/1.1
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}


### 请求密码重置

# @name passwordResetRequest

POST {{baseUrl}}/auth/password-reset/request HTTP/1.1
Content-Type: application/json

{
  "phone": "{{testPhone}}"
}


### 发送短信验证码

# @name sendSMS

POST {{baseUrl}}/auth/sms/send HTTP/1.1
Content-Type: application/json

{
  "phone": "{{testPhone}}"
}


### 验证短信验证码

# @name verifySMS

POST {{baseUrl}}/auth/sms/verify HTTP/1.1
Content-Type: application/json

{
  "code": "123456",
  "phone": "{{testPhone}}"
}
